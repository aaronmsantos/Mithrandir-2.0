# ⚡️ Mithrandir 2.0 Environment Configuration Template

# Model API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Journal Encryption (Symmetric Key)
# Generate a valid key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MITHRANDIR_JOURNAL_KEY=your_base64_symmetric_key_here

# Spotify Integration
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback
